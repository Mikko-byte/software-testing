  "author": "",
  "license": "MIT",
  "devDependencies": {
    "coveralls": "^3.1.1",
    "jest": "^30.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/.internal/**"
    ]
  }
}